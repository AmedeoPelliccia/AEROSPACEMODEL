{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ampel360.com/schemas/ipd/ipd_source_data.schema.json",
  "title": "IPD Source Data Schema",
  "description": "Schema for vendor source package entries in an IPD module per AMPEL360 Q100 approved vendor list (AVL) conventions and S1000D Issue 5.0.",
  "type": "object",
  "required": ["id", "title", "vendor", "status", "date"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Approved vendor package identifier",
      "pattern": "^AMPEL-VP-[0-9]{4}-[0-9]{3}$",
      "examples": ["AMPEL-VP-2820-001", "AMPEL-VP-2820-002"]
    },
    "title": {
      "type": "string",
      "description": "Descriptive title of the vendor source package",
      "minLength": 1,
      "examples": [
        "Shut-Off Valve Assembly – Primary Source",
        "Cryogenic Seals – PTFE Grade"
      ]
    },
    "vendor": {
      "type": "string",
      "description": "Vendor or manufacturer name",
      "minLength": 1,
      "examples": ["Parker Hannifin Cryogenics", "Flowserve Corporation"]
    },
    "status": {
      "type": "string",
      "description": "Approval status of the vendor source package",
      "enum": ["APPROVED", "QUAL-TEST", "DRAFT", "REJECTED"],
      "examples": ["APPROVED", "QUAL-TEST", "DRAFT"]
    },
    "date": {
      "type": "string",
      "description": "Approval or last review date in ISO 8601 format (YYYY-MM-DD)",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "examples": ["2026-01-15", "2025-11-30"]
    }
  },
  "additionalProperties": false
}
